<Window x:Class="_17._01___Pi__WPF_.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:_17._01___Pi__WPF_"
        mc:Ignorable="d"
        Title="Berechnung von Pi" Height="150" Width="250">
    <Grid Margin="0,0,0,8">
        <Button x:Name="BerechnenButton" Content="Berechnen" HorizontalAlignment="Center" Margin="0,41,0,0" VerticalAlignment="Top" Click="BerechnungStarten"/>
        <Label x:Name="ErgebnisLabel" Content="Klicken Sie auf Berechnen" HorizontalAlignment="Center" Margin="0,10,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.819,1.257" BorderBrush="Red" Background="#FFE0E0E0"/>
        <Button x:Name="AbbrechenButton" Content="Abbrechen" HorizontalAlignment="Center" Margin="0,66,0,0" VerticalAlignment="Top" Click="Abbrechen"/>
        <ProgressBar x:Name="Bar" HorizontalAlignment="Center" Height="10" Margin="0,91,0,0" VerticalAlignment="Top" Width="100"/>

    </Grid>
</Window>
